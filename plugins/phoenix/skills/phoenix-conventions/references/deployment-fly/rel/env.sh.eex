#!/bin/sh

if [ -n "$FLY_APP_NAME" ]; then
  export DNS_CLUSTER_QUERY="${FLY_APP_NAME}.internal"
  export RELEASE_NODE="${FLY_APP_NAME}-${FLY_IMAGE_REF##*-}@${FLY_PRIVATE_IP}"
  # configure node for distributed erlang with IPv6 support
  export ERL_AFLAGS="-proto_dist inet6_tcp"
  export ECTO_IPV6="true"
fi

export RELEASE_DISTRIBUTION="name"

# RELEASE_COOKIE is set as a separate Fly secret (its own UUID — never
# piggyback on another secret). The release boot machinery picks it up
# automatically from the env. Without it, `mix release` bakes a fresh
# random cookie per build, so old/new releases in a rolling deploy
# can't reach each other.

# When not running on Fly, fall back to a sensible default so `mix release`
# works locally without RELEASE_NODE pre-set.
export RELEASE_NODE=${RELEASE_NODE:-<%= @release.name %>@$(hostname)}
